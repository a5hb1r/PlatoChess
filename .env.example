# Supabase (Project Settings → API: Project URL + anon public key)
VITE_SUPABASE_URL=https://xxxx.supabase.co
# Same value Supabase labels "anon" / "publishable" — must match client.ts
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_public_key

# Monitoring (optional, recommended for production)
VITE_SENTRY_DSN=

# Optional app store listing URLs shown in footer
VITE_APPLE_APP_STORE_URL=https://apps.apple.com/app/id1234567890
VITE_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.example.platochess

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Server-side Supabase admin (required for Stripe webhook profile sync)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
